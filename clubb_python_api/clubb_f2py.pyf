    ! --- forcings_wrapper: prescribe_forcings ---

    subroutine f2py_prescribe_forcings( &
        nzm, nzt, ngrdcol, sclr_dim, edsclr_dim, sclr_dim_transport, edsclr_dim_transport, &
        runtype, sfctype, time_current, time_initial, dt, &
        um, vm, thlm, p_in_pa, exner, rho, rho_zm, thvm, zt_in, &
        l_t_dependent, l_ignore_forcings, l_input_xpwp_sfc, &
        l_modify_bc_for_cnvg_test, &
        saturation_formula, l_add_dycore_grid, grid_remap_method, &
        grid_adapt_in_time_method, &
        rtm, wm_zm, wm_zt, ug, vg, um_ref, vm_ref, &
        thlm_forcing, rtm_forcing, um_forcing, vm_forcing, &
        wprtp_forcing, wpthlp_forcing, rtp2_forcing, thlp2_forcing, rtpthlp_forcing, &
        wpsclrp, sclrm_forcing, edsclrm_forcing, &
        wpthlp_sfc, wprtp_sfc, upwp_sfc, vpwp_sfc, &
        t_sfc, p_sfc, sens_ht, latent_ht, &
        wpsclrp_sfc, wpedsclrp_sfc)
      integer, intent(in) :: nzm, nzt, ngrdcol, sclr_dim, edsclr_dim
      integer, intent(in), optional :: sclr_dim_transport, edsclr_dim_transport
      character(len=50), intent(in) :: runtype
      integer, intent(in) :: sfctype
      double precision, intent(in) :: time_current, time_initial, dt
      logical, intent(in) :: l_t_dependent, l_ignore_forcings, l_input_xpwp_sfc
      logical, intent(in) :: l_modify_bc_for_cnvg_test
      integer, intent(in) :: saturation_formula
      logical, intent(in) :: l_add_dycore_grid
      integer, intent(in) :: grid_remap_method, grid_adapt_in_time_method
      ! Input profiles
      double precision, dimension(ngrdcol, nzt), intent(in) :: &
        um, vm, thlm, p_in_pa, exner, rho, thvm, zt_in
      double precision, dimension(ngrdcol, nzm), intent(in) :: rho_zm
      ! In/out state updated by prescribe_forcings
      double precision, dimension(ngrdcol, nzt), intent(in,out) :: &
        rtm, wm_zt, ug, vg, um_ref, vm_ref, &
        thlm_forcing, rtm_forcing, um_forcing, vm_forcing
      double precision, dimension(ngrdcol, nzm), intent(in,out) :: &
        wm_zm, wprtp_forcing, wpthlp_forcing, &
        rtp2_forcing, thlp2_forcing, rtpthlp_forcing
      double precision, dimension(ngrdcol, nzm, sclr_dim_transport), intent(in,out) :: wpsclrp
      double precision, dimension(ngrdcol, nzt, sclr_dim_transport), intent(in,out) :: sclrm_forcing
      double precision, dimension(ngrdcol, nzt, edsclr_dim_transport), intent(in,out) :: edsclrm_forcing
      double precision, dimension(ngrdcol), intent(in,out) :: &
        wpthlp_sfc, wprtp_sfc, upwp_sfc, vpwp_sfc, t_sfc, p_sfc
      double precision, intent(in,out) :: sens_ht, latent_ht
      double precision, dimension(ngrdcol, sclr_dim_transport), intent(in,out) :: wpsclrp_sfc
      double precision, dimension(ngrdcol, edsclr_dim_transport), intent(in,out) :: wpedsclrp_sfc
    end subroutine

    ! --- advance_clubb_core_module_wrapper: advance_clubb_core ---

    subroutine f2py_advance_clubb_core( &
        nzm, nzt, ngrdcol, &
        l_implemented, dt, &
        fcor, fcor_y, sfc_elevation, &
        hydromet_dim, sclr_dim, edsclr_dim, &
        hydromet_dim_transport, sclr_dim_transport, edsclr_dim_transport, &
        sclr_tol, &
        thlm_forcing, rtm_forcing, um_forcing, vm_forcing, &
        sclrm_forcing, edsclrm_forcing, &
        wprtp_forcing, wpthlp_forcing, rtp2_forcing, thlp2_forcing, &
        rtpthlp_forcing, wm_zm, wm_zt, &
        wpthlp_sfc, wprtp_sfc, upwp_sfc, vpwp_sfc, p_sfc, &
        wpsclrp_sfc, wpedsclrp_sfc, &
        upwp_sfc_pert, vpwp_sfc_pert, &
        rtm_ref, thlm_ref, um_ref, vm_ref, ug, vg, &
        rho_zm, rho, rho_ds_zm, rho_ds_zt, invrs_rho_ds_zm, invrs_rho_ds_zt, thv_ds_zm, thv_ds_zt, &
        l_mix_rat_hm, &
        rfrzm, &
        wphydrometp, wp2hmp, rtphmp_zt, thlphmp_zt, &
        host_dx, host_dy, &
        clubb_params, lmin, mixt_frac_max_mag, t0_val, ts_nudge, &
        rtm_min, rtm_nudge_max_altitude, &
        um, vm, up3, vp3, thlm, rtm, rtp3, thlp3, wp3, &
        upwp, vpwp, up2, vp2, wprtp, wpthlp, rtp2, thlp2, rtpthlp, wp2, &
        sclrm, sclrp3, &
        wpsclrp, sclrp2, sclrprtp, sclrpthlp, &
        p_in_pa, exner, rcm, cloud_frac, wp2thvp, wp2up, &
        wpthvp, rtpthvp, thlpthvp, &
        sclrpthvp, &
        wp2rtp, wp2thlp, wpup2, wpvp2, ice_supersat_frac, &
        uprcp, vprcp, rc_coef_zm, wp4, wp2up2, wp2vp2, &
        um_pert, vm_pert, upwp_pert, vpwp_pert, &
        edsclrm, &
        rcm_in_layer, cloud_cover, w_up_in_cloud, w_down_in_cloud, &
        cloudy_updraft_frac, cloudy_downdraft_frac, wprcp, invrs_tau_zm, &
        kh_zt, kh_zm, thlprcp, lscale)
      integer, intent(in) :: nzm, nzt, ngrdcol
      logical, intent(in) :: l_implemented
      double precision, intent(in) :: dt
      double precision, dimension(ngrdcol), intent(in) :: fcor, fcor_y, sfc_elevation
      integer, intent(in) :: hydromet_dim, sclr_dim, edsclr_dim
      integer, intent(in), optional :: hydromet_dim_transport, sclr_dim_transport, edsclr_dim_transport
      double precision, dimension(sclr_dim), intent(in) :: sclr_tol
      ! 2D inputs on zt
      double precision, dimension(ngrdcol, nzt), intent(in) :: &
        thlm_forcing, rtm_forcing, um_forcing, vm_forcing
      ! Scalar forcings
      double precision, dimension(ngrdcol, nzt, sclr_dim_transport), intent(in) :: sclrm_forcing
      double precision, dimension(ngrdcol, nzt, edsclr_dim_transport), intent(in) :: edsclrm_forcing
      ! 2D inputs on zm / grid
      double precision, dimension(ngrdcol, nzm), intent(in) :: &
        wprtp_forcing, wpthlp_forcing, rtp2_forcing, thlp2_forcing, &
        rtpthlp_forcing, wm_zm, rho_zm, rho_ds_zm, invrs_rho_ds_zm, thv_ds_zm
      double precision, dimension(ngrdcol, nzt), intent(in) :: &
        wm_zt, rtm_ref, thlm_ref, um_ref, vm_ref, ug, vg, rho, &
        rho_ds_zt, invrs_rho_ds_zt, thv_ds_zt, rfrzm
      ! Surface fluxes
      double precision, dimension(ngrdcol), intent(in) :: &
        wpthlp_sfc, wprtp_sfc, upwp_sfc, vpwp_sfc, p_sfc, &
        upwp_sfc_pert, vpwp_sfc_pert, host_dx, host_dy
      double precision, dimension(ngrdcol, sclr_dim_transport), intent(in) :: wpsclrp_sfc
      double precision, dimension(ngrdcol, edsclr_dim_transport), intent(in) :: wpedsclrp_sfc
      ! Tunable params
      double precision, dimension(ngrdcol, *), intent(in) :: clubb_params
      double precision, intent(in) :: lmin, mixt_frac_max_mag, t0_val, ts_nudge
      double precision, intent(in) :: rtm_min, rtm_nudge_max_altitude
      ! Hydromet
      logical, dimension(hydromet_dim_transport), intent(in) :: l_mix_rat_hm
      double precision, dimension(ngrdcol, nzm, hydromet_dim_transport), intent(in) :: wphydrometp
      double precision, dimension(ngrdcol, nzt, hydromet_dim_transport), intent(in) :: &
        wp2hmp, rtphmp_zt, thlphmp_zt
      ! Prognostic inout - zt
      double precision, dimension(ngrdcol, nzt), intent(in,out) :: &
        um, vm, up3, vp3, thlm, rtm, rtp3, thlp3, wp3
      ! Prognostic inout - zm
      double precision, dimension(ngrdcol, nzm), intent(in,out) :: &
        upwp, vpwp, up2, vp2, wprtp, wpthlp, rtp2, thlp2, rtpthlp, wp2
      ! Scalar prognostics
      double precision, dimension(ngrdcol, nzt, sclr_dim_transport), intent(in,out) :: sclrm, sclrp3
      double precision, dimension(ngrdcol, nzm, sclr_dim_transport), intent(in,out) :: &
        wpsclrp, sclrp2, sclrprtp, sclrpthlp
      double precision, dimension(ngrdcol, nzt), intent(in,out) :: &
        p_in_pa, exner, rcm, cloud_frac, wp2thvp, wp2up
      double precision, dimension(ngrdcol, nzm), intent(in,out) :: &
        wpthvp, rtpthvp, thlpthvp
      double precision, dimension(ngrdcol, nzm, sclr_dim_transport), intent(in,out) :: sclrpthvp
      double precision, dimension(ngrdcol, nzt), intent(in,out) :: &
        wp2rtp, wp2thlp, wpup2, wpvp2, ice_supersat_frac
      double precision, dimension(ngrdcol, nzm), intent(in,out) :: &
        uprcp, vprcp, rc_coef_zm, wp4, wp2up2, wp2vp2
      double precision, dimension(ngrdcol, nzt), intent(in,out) :: um_pert, vm_pert
      double precision, dimension(ngrdcol, nzm), intent(in,out) :: upwp_pert, vpwp_pert
      double precision, dimension(ngrdcol, nzt, edsclr_dim_transport), intent(in,out) :: edsclrm
      ! Output - zt
      double precision, dimension(ngrdcol, nzt), intent(out) :: &
        rcm_in_layer, cloud_cover, w_up_in_cloud, w_down_in_cloud, cloudy_updraft_frac, &
        cloudy_downdraft_frac, kh_zt, lscale
      ! Output - zm
      double precision, dimension(ngrdcol, nzm), intent(out) :: &
        wprcp, invrs_tau_zm, kh_zm, thlprcp
    end subroutine

