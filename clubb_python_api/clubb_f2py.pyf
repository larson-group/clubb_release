!  clubb_f2py.pyf - F2PY signature file for the CLUBB Python interface.
!
!  This file defines the Python-visible function signatures for all
!  Fortran wrapper subroutines. F2PY uses this to generate the Python
!  module without needing to parse the actual Fortran source (which
!  contains UDTs that F2PY cannot handle).
!
!  Maintenance: when adding a new Fortran wrapper subroutine, add its
!  signature here with matching argument names, types, intents, and shapes.

python module clubb_f2py
  interface

    ! --- Grid setters/getters ---
    subroutine set_grid(nzm, nzt, ngrdcol, &
                        zm, zt, dzm, dzt, invrs_dzm, invrs_dzt, &
                        weights_zt2zm, weights_zm2zt, &
                        k_lb_zm, k_ub_zm, k_lb_zt, k_ub_zt, &
                        grid_dir_indx, grid_dir)
      integer, intent(in) :: nzm, nzt, ngrdcol
      double precision, dimension(ngrdcol, nzm), intent(in) :: zm, dzm, invrs_dzm
      double precision, dimension(ngrdcol, nzt), intent(in) :: zt, dzt, invrs_dzt
      double precision, dimension(ngrdcol, nzm, 2), intent(in) :: weights_zt2zm
      double precision, dimension(ngrdcol, nzt, 2), intent(in) :: weights_zm2zt
      integer, intent(in) :: k_lb_zm, k_ub_zm, k_lb_zt, k_ub_zt, grid_dir_indx
      double precision, intent(in) :: grid_dir
    end subroutine

    subroutine get_grid(ngrdcol, nzm, nzt, &
                        zm, zt, dzm, dzt, invrs_dzm, invrs_dzt, &
                        weights_zt2zm, weights_zm2zt, &
                        k_lb_zm, k_ub_zm, k_lb_zt, k_ub_zt, &
                        grid_dir_indx, grid_dir)
      integer, intent(in)  :: ngrdcol, nzm, nzt
      double precision, dimension(ngrdcol, nzm), intent(out) :: zm, dzm, invrs_dzm
      double precision, dimension(ngrdcol, nzt), intent(out) :: zt, dzt, invrs_dzt
      double precision, dimension(ngrdcol, nzm, 2), intent(out) :: weights_zt2zm
      double precision, dimension(ngrdcol, nzt, 2), intent(out) :: weights_zm2zt
      integer, intent(out) :: k_lb_zm, k_ub_zm, k_lb_zt, k_ub_zt, grid_dir_indx
      double precision, intent(out) :: grid_dir
    end subroutine

    ! --- Scalar index setter/getter ---
    subroutine set_sclr_idx(iisclr_rt, iisclr_thl, iisclr_co2, &
                            iiedsclr_rt, iiedsclr_thl, iiedsclr_co2)
      integer, intent(in) :: iisclr_rt, iisclr_thl, iisclr_co2
      integer, intent(in) :: iiedsclr_rt, iiedsclr_thl, iiedsclr_co2
    end subroutine

    subroutine get_sclr_idx(iisclr_rt, iisclr_thl, iisclr_co2, &
                            iiedsclr_rt, iiedsclr_thl, iiedsclr_co2)
      integer, intent(out) :: iisclr_rt, iisclr_thl, iisclr_co2
      integer, intent(out) :: iiedsclr_rt, iiedsclr_thl, iiedsclr_co2
    end subroutine

    ! --- nu_vertical_res_dep setter/getter ---
    subroutine set_nu_vert_res_dep(nzm, nu1, nu2, nu6, nu8, nu9, nu10, nu_hm)
      integer, intent(in) :: nzm
      double precision, dimension(nzm), intent(in) :: nu1, nu2, nu6, nu8, nu9, nu10, nu_hm
    end subroutine

    subroutine get_nu_vert_res_dep(nzm, nu1, nu2, nu6, nu8, nu9, nu10, nu_hm)
      integer, intent(in) :: nzm
      double precision, dimension(nzm), intent(out) :: nu1, nu2, nu6, nu8, nu9, nu10, nu_hm
    end subroutine

    ! --- err_info getters ---
    subroutine get_err_info_dims(ngrdcol)
      integer, intent(out) :: ngrdcol
    end subroutine

    ! --- Error code getter ---
    subroutine get_err_code(ngrdcol, err_code)
      integer, intent(in)  :: ngrdcol
      integer, intent(out) :: err_code(ngrdcol)
    end subroutine

    ! --- calc_pressure_wrapper: init_pressure ---
    subroutine f2py_init_pressure(ngrdcol, nzt, nzm, thvm, p_sfc, &
                                  p_in_Pa, exner, p_in_Pa_zm, exner_zm)
      integer, intent(in) :: ngrdcol, nzt, nzm
      double precision, dimension(ngrdcol, nzt), intent(in)  :: thvm
      double precision, dimension(ngrdcol),      intent(in)  :: p_sfc
      double precision, dimension(ngrdcol, nzt), intent(out) :: p_in_Pa, exner
      double precision, dimension(ngrdcol, nzm), intent(out) :: p_in_Pa_zm, exner_zm
    end subroutine

    subroutine f2py_get_grid_dims(nzm_out, nzt_out)
      integer, intent(out) :: nzm_out, nzt_out
    end subroutine

    subroutine f2py_get_grid_shape(ngrdcol_out, nzm_out, nzt_out)
      integer, intent(out) :: ngrdcol_out, nzm_out, nzt_out
    end subroutine

    ! --- matrix_solver_wrapper: solver entry points ---
    subroutine f2py_band_solve_multiple_rhs(solve_name, penta_solve_method, &
                                            ngrdcol, nsup, nsub, ndim, nrhs, &
                                            lhs, rhs, old_soln, use_rcond, soln, rcond)
      character(len=*), intent(in) :: solve_name
      integer, intent(in) :: penta_solve_method, ngrdcol, nsup, nsub, ndim, nrhs
      double precision, dimension(nsup+nsub+1, ngrdcol, ndim), intent(in,out) :: lhs
      double precision, dimension(ngrdcol, ndim, nrhs), intent(in,out) :: rhs
      double precision, dimension(ngrdcol, ndim, nrhs), intent(in) :: old_soln
      logical, intent(in) :: use_rcond
      double precision, dimension(ngrdcol, ndim, nrhs), intent(out) :: soln
      double precision, dimension(ngrdcol), intent(out) :: rcond
    end subroutine

    subroutine f2py_tridiag_solve_single_rhs_multiple_lhs(solve_name, tridiag_solve_method, &
                                                           ngrdcol, ndim, lhs, rhs, use_rcond, &
                                                           soln, rcond)
      character(len=*), intent(in) :: solve_name
      integer, intent(in) :: tridiag_solve_method, ngrdcol, ndim
      double precision, dimension(3, ngrdcol, ndim), intent(in,out) :: lhs
      double precision, dimension(ngrdcol, ndim), intent(in,out) :: rhs
      logical, intent(in) :: use_rcond
      double precision, dimension(ngrdcol, ndim), intent(out) :: soln
      double precision, dimension(ngrdcol), intent(out) :: rcond
    end subroutine

    subroutine f2py_tridiag_solve_multiple_rhs(solve_name, tridiag_solve_method, &
                                               ngrdcol, ndim, nrhs, lhs, rhs, use_rcond, &
                                               soln, rcond)
      character(len=*), intent(in) :: solve_name
      integer, intent(in) :: tridiag_solve_method, ngrdcol, ndim, nrhs
      double precision, dimension(3, ngrdcol, ndim), intent(in,out) :: lhs
      double precision, dimension(ngrdcol, ndim, nrhs), intent(in,out) :: rhs
      logical, intent(in) :: use_rcond
      double precision, dimension(ngrdcol, ndim, nrhs), intent(out) :: soln
      double precision, dimension(ngrdcol), intent(out) :: rcond
    end subroutine

    subroutine f2py_lapack_gtsv(n, nrhs, dl, d, du, b, soln, info)
      integer, intent(in) :: n, nrhs
      double precision, dimension(n-1), intent(in) :: dl, du
      double precision, dimension(n), intent(in) :: d
      double precision, dimension(n, nrhs), intent(in) :: b
      double precision, dimension(n, nrhs), intent(out) :: soln
      integer, intent(out) :: info
    end subroutine

    subroutine f2py_lapack_gtsvx(n, nrhs, dl, d, du, b, soln, rcond, ferr, berr, info)
      integer, intent(in) :: n, nrhs
      double precision, dimension(n-1), intent(in) :: dl, du
      double precision, dimension(n), intent(in) :: d
      double precision, dimension(n, nrhs), intent(in) :: b
      double precision, dimension(n, nrhs), intent(out) :: soln
      double precision, intent(out) :: rcond
      double precision, dimension(nrhs), intent(out) :: ferr, berr
      integer, intent(out) :: info
    end subroutine

    subroutine f2py_lapack_gbsv(n, kl, ku, nrhs, ab, b, soln, ipiv, info)
      integer, intent(in) :: n, kl, ku, nrhs
      double precision, dimension(2*kl+ku+1, n), intent(in) :: ab
      double precision, dimension(n, nrhs), intent(in) :: b
      double precision, dimension(n, nrhs), intent(out) :: soln
      integer, dimension(n), intent(out) :: ipiv
      integer, intent(out) :: info
    end subroutine

    subroutine f2py_lapack_gbsvx(n, kl, ku, nrhs, ab, b, soln, rcond, ferr, berr, equed, info)
      integer, intent(in) :: n, kl, ku, nrhs
      double precision, dimension(kl+ku+1, n), intent(in) :: ab
      double precision, dimension(n, nrhs), intent(in) :: b
      double precision, dimension(n, nrhs), intent(out) :: soln
      double precision, intent(out) :: rcond
      double precision, dimension(nrhs), intent(out) :: ferr, berr
      character, intent(out) :: equed
      integer, intent(out) :: info
    end subroutine

    subroutine f2py_lapack_potrf(uplo, n, a, a_factor, info)
      character(len=*), intent(in) :: uplo
      integer, intent(in) :: n
      double precision, dimension(n, n), intent(in) :: a
      double precision, dimension(n, n), intent(out) :: a_factor
      integer, intent(out) :: info
    end subroutine

    subroutine f2py_lapack_poequ(n, a, s, scond, amax, info)
      integer, intent(in) :: n
      double precision, dimension(n, n), intent(in) :: a
      double precision, dimension(n), intent(out) :: s
      double precision, intent(out) :: scond, amax
      integer, intent(out) :: info
    end subroutine

    subroutine f2py_lapack_laqsy(uplo, n, a, s, scond, amax, a_equed, equed)
      character(len=*), intent(in) :: uplo
      integer, intent(in) :: n
      double precision, dimension(n, n), intent(in) :: a
      double precision, dimension(n), intent(in) :: s
      double precision, intent(in) :: scond, amax
      double precision, dimension(n, n), intent(out) :: a_equed
      character, intent(out) :: equed
    end subroutine

    subroutine f2py_lapack_syev(jobz, uplo, n, a, a_out, w, info)
      character(len=*), intent(in) :: jobz, uplo
      integer, intent(in) :: n
      double precision, dimension(n, n), intent(in) :: a
      double precision, dimension(n, n), intent(out) :: a_out
      double precision, dimension(n), intent(out) :: w
      integer, intent(out) :: info
    end subroutine

    subroutine f2py_lapack_tridiag_solve(solve_type, ndim, nrhs, ngrdcol, lhs, rhs, soln)
      character(len=*), intent(in) :: solve_type
      integer, intent(in) :: ndim, nrhs, ngrdcol
      double precision, dimension(3, ngrdcol, ndim), intent(in) :: lhs
      double precision, dimension(ngrdcol, ndim, nrhs), intent(in) :: rhs
      double precision, dimension(ngrdcol, ndim, nrhs), intent(out) :: soln
    end subroutine

    subroutine f2py_lapack_tridiag_solvex(solve_type, ndim, nrhs, ngrdcol, lhs, rhs, soln, rcond)
      character(len=*), intent(in) :: solve_type
      integer, intent(in) :: ndim, nrhs, ngrdcol
      double precision, dimension(3, ngrdcol, ndim), intent(in) :: lhs
      double precision, dimension(ngrdcol, ndim, nrhs), intent(in) :: rhs
      double precision, dimension(ngrdcol, ndim, nrhs), intent(out) :: soln
      double precision, dimension(ngrdcol), intent(out) :: rcond
    end subroutine

    subroutine f2py_lapack_band_solve(solve_type, nsup, nsub, ndim, nrhs, ngrdcol, lhs, rhs, soln)
      character(len=*), intent(in) :: solve_type
      integer, intent(in) :: nsup, nsub, ndim, nrhs, ngrdcol
      double precision, dimension(nsup+nsub+1, ngrdcol, ndim), intent(in) :: lhs
      double precision, dimension(ngrdcol, ndim, nrhs), intent(in) :: rhs
      double precision, dimension(ngrdcol, ndim, nrhs), intent(out) :: soln
    end subroutine

    subroutine f2py_lapack_band_solvex(solve_type, nsup, nsub, ndim, nrhs, ngrdcol, lhs, rhs, soln, rcond)
      character(len=*), intent(in) :: solve_type
      integer, intent(in) :: nsup, nsub, ndim, nrhs, ngrdcol
      double precision, dimension(nsup+nsub+1, ngrdcol, ndim), intent(in) :: lhs
      double precision, dimension(ngrdcol, ndim, nrhs), intent(in) :: rhs
      double precision, dimension(ngrdcol, ndim, nrhs), intent(out) :: soln
      double precision, dimension(ngrdcol), intent(out) :: rcond
    end subroutine

    subroutine f2py_penta_bicgstab_solve(ndim, ngrdcol, lhs, rhs, soln, iters)
      integer, intent(in) :: ndim, ngrdcol
      double precision, dimension(5, ngrdcol, ndim), intent(in) :: lhs
      double precision, dimension(ngrdcol, ndim), intent(in) :: rhs
      double precision, dimension(ngrdcol, ndim), intent(out) :: soln
      integer, intent(out) :: iters
    end subroutine

    subroutine f2py_penta_lu_solve_single_rhs_multiple_lhs(ndim, ngrdcol, lhs, rhs, soln)
      integer, intent(in) :: ndim, ngrdcol
      double precision, dimension(5, ngrdcol, ndim), intent(in) :: lhs
      double precision, dimension(ngrdcol, ndim), intent(in) :: rhs
      double precision, dimension(ngrdcol, ndim), intent(out) :: soln
    end subroutine

    subroutine f2py_penta_lu_solve_multiple_rhs_lhs(ndim, nrhs, ngrdcol, lhs, rhs, soln)
      integer, intent(in) :: ndim, nrhs, ngrdcol
      double precision, dimension(5, ngrdcol, ndim), intent(in) :: lhs
      double precision, dimension(ngrdcol, ndim, nrhs), intent(in) :: rhs
      double precision, dimension(ngrdcol, ndim, nrhs), intent(out) :: soln
    end subroutine

    subroutine f2py_tridiag_lu_solve_single_rhs_lhs(ndim, lhs, rhs, soln)
      integer, intent(in) :: ndim
      double precision, dimension(3, ndim), intent(in) :: lhs
      double precision, dimension(ndim), intent(in) :: rhs
      double precision, dimension(ndim), intent(out) :: soln
    end subroutine

    subroutine f2py_tridiag_lu_solve_single_rhs_multiple_lhs(ndim, ngrdcol, lhs, rhs, soln)
      integer, intent(in) :: ndim, ngrdcol
      double precision, dimension(3, ngrdcol, ndim), intent(in) :: lhs
      double precision, dimension(ngrdcol, ndim), intent(in) :: rhs
      double precision, dimension(ngrdcol, ndim), intent(out) :: soln
    end subroutine

    subroutine f2py_tridiag_lu_solve_multiple_rhs_lhs(ndim, nrhs, ngrdcol, lhs, rhs, soln)
      integer, intent(in) :: ndim, nrhs, ngrdcol
      double precision, dimension(3, ngrdcol, ndim), intent(in) :: lhs
      double precision, dimension(ngrdcol, ndim, nrhs), intent(in) :: rhs
      double precision, dimension(ngrdcol, ndim, nrhs), intent(out) :: soln
    end subroutine

    ! --- T_in_K_wrapper: temperature conversion ---
    subroutine f2py_thlm2t_in_k_1d(nz, thlm, exner, rcm, t_in_k)
      integer, intent(in) :: nz
      double precision, dimension(nz), intent(in) :: thlm, exner, rcm
      double precision, dimension(nz), intent(out) :: t_in_k
    end subroutine

    ! --- init_wrappers: initialization routines ---

    subroutine f2py_init_err_info(ngrdcol)
      integer, intent(in) :: ngrdcol
    end subroutine

    subroutine f2py_set_default_config_flags( &
        iiPDF_type, ipdf_call_placement, penta_solve_method, &
        tridiag_solve_method, saturation_formula, grid_remap_method, &
        grid_adapt_in_time_method, fill_holes_type, &
        l_use_precip_frac, l_predict_upwp_vpwp, &
        l_ho_nontrad_coriolis, l_ho_trad_coriolis, &
        l_min_wp2_from_corr_wx, l_min_xp2_from_corr_wx, &
        l_C2_cloud_frac, l_diffuse_rtm_and_thlm, &
        l_stability_correct_Kh_N2_zm, l_calc_thlp2_rad, &
        l_upwind_xpyp_ta, l_upwind_xm_ma, &
        l_uv_nudge, l_rtm_nudge, l_tke_aniso, &
        l_vert_avg_closure, l_trapezoidal_rule_zt, &
        l_trapezoidal_rule_zm, l_call_pdf_closure_twice, &
        l_standard_term_ta, l_partial_upwind_wp3, &
        l_godunov_upwind_wpxp_ta, l_godunov_upwind_xpyp_ta, &
        l_use_cloud_cover, l_diagnose_correlations, &
        l_calc_w_corr, l_const_Nc_in_cloud, &
        l_fix_w_chi_eta_correlations, l_stability_correct_tau_zm, &
        l_damp_wp2_using_em, l_do_expldiff_rtm_thlm, &
        l_Lscale_plume_centered, l_diag_Lscale_from_tau, &
        l_use_C7_Richardson, l_use_C11_Richardson, &
        l_use_shear_Richardson, l_brunt_vaisala_freq_moist, &
        l_use_thvm_in_bv_freq, l_rcm_supersat_adj, &
        l_damp_wp3_Skw_squared, l_prescribed_avg_deltaz, &
        l_lmm_stepping, l_e3sm_config, l_vary_convect_depth, &
        l_use_tke_in_wp3_pr_turb_term, l_use_tke_in_wp2_wp3_K_dfsn, &
        l_use_wp3_lim_with_smth_Heaviside, &
        l_smooth_Heaviside_tau_wpxp, &
        l_modify_limiters_for_cnvg_test, &
        l_enable_relaxed_clipping, l_linearize_pbl_winds, &
        l_mono_flux_lim_thlm, l_mono_flux_lim_rtm, &
        l_mono_flux_lim_um, l_mono_flux_lim_vm, &
        l_mono_flux_lim_spikefix, l_host_applies_sfc_fluxes, &
        l_wp2_fill_holes_tke, l_add_dycore_grid)
      integer, intent(out) :: iiPDF_type, ipdf_call_placement
      integer, intent(out) :: penta_solve_method, tridiag_solve_method
      integer, intent(out) :: saturation_formula, grid_remap_method
      integer, intent(out) :: grid_adapt_in_time_method, fill_holes_type
      logical, intent(out) :: l_use_precip_frac, l_predict_upwp_vpwp
      logical, intent(out) :: l_ho_nontrad_coriolis, l_ho_trad_coriolis
      logical, intent(out) :: l_min_wp2_from_corr_wx, l_min_xp2_from_corr_wx
      logical, intent(out) :: l_C2_cloud_frac, l_diffuse_rtm_and_thlm
      logical, intent(out) :: l_stability_correct_Kh_N2_zm, l_calc_thlp2_rad
      logical, intent(out) :: l_upwind_xpyp_ta, l_upwind_xm_ma
      logical, intent(out) :: l_uv_nudge, l_rtm_nudge, l_tke_aniso
      logical, intent(out) :: l_vert_avg_closure, l_trapezoidal_rule_zt
      logical, intent(out) :: l_trapezoidal_rule_zm, l_call_pdf_closure_twice
      logical, intent(out) :: l_standard_term_ta, l_partial_upwind_wp3
      logical, intent(out) :: l_godunov_upwind_wpxp_ta, l_godunov_upwind_xpyp_ta
      logical, intent(out) :: l_use_cloud_cover, l_diagnose_correlations
      logical, intent(out) :: l_calc_w_corr, l_const_Nc_in_cloud
      logical, intent(out) :: l_fix_w_chi_eta_correlations, l_stability_correct_tau_zm
      logical, intent(out) :: l_damp_wp2_using_em, l_do_expldiff_rtm_thlm
      logical, intent(out) :: l_Lscale_plume_centered, l_diag_Lscale_from_tau
      logical, intent(out) :: l_use_C7_Richardson, l_use_C11_Richardson
      logical, intent(out) :: l_use_shear_Richardson, l_brunt_vaisala_freq_moist
      logical, intent(out) :: l_use_thvm_in_bv_freq, l_rcm_supersat_adj
      logical, intent(out) :: l_damp_wp3_Skw_squared, l_prescribed_avg_deltaz
      logical, intent(out) :: l_lmm_stepping, l_e3sm_config, l_vary_convect_depth
      logical, intent(out) :: l_use_tke_in_wp3_pr_turb_term
      logical, intent(out) :: l_use_tke_in_wp2_wp3_K_dfsn
      logical, intent(out) :: l_use_wp3_lim_with_smth_Heaviside
      logical, intent(out) :: l_smooth_Heaviside_tau_wpxp
      logical, intent(out) :: l_modify_limiters_for_cnvg_test
      logical, intent(out) :: l_enable_relaxed_clipping, l_linearize_pbl_winds
      logical, intent(out) :: l_mono_flux_lim_thlm, l_mono_flux_lim_rtm
      logical, intent(out) :: l_mono_flux_lim_um, l_mono_flux_lim_vm
      logical, intent(out) :: l_mono_flux_lim_spikefix, l_host_applies_sfc_fluxes
      logical, intent(out) :: l_wp2_fill_holes_tke, l_add_dycore_grid
    end subroutine

    subroutine f2py_init_config_flags( &
        iiPDF_type, ipdf_call_placement, penta_solve_method, &
        tridiag_solve_method, saturation_formula, grid_remap_method, &
        grid_adapt_in_time_method, fill_holes_type, &
        l_use_precip_frac, l_predict_upwp_vpwp, &
        l_ho_nontrad_coriolis, l_ho_trad_coriolis, &
        l_min_wp2_from_corr_wx, l_min_xp2_from_corr_wx, &
        l_C2_cloud_frac, l_diffuse_rtm_and_thlm, &
        l_stability_correct_Kh_N2_zm, l_calc_thlp2_rad, &
        l_upwind_xpyp_ta, l_upwind_xm_ma, &
        l_uv_nudge, l_rtm_nudge, l_tke_aniso, &
        l_vert_avg_closure, l_trapezoidal_rule_zt, &
        l_trapezoidal_rule_zm, l_call_pdf_closure_twice, &
        l_standard_term_ta, l_partial_upwind_wp3, &
        l_godunov_upwind_wpxp_ta, l_godunov_upwind_xpyp_ta, &
        l_use_cloud_cover, l_diagnose_correlations, &
        l_calc_w_corr, l_const_Nc_in_cloud, &
        l_fix_w_chi_eta_correlations, l_stability_correct_tau_zm, &
        l_damp_wp2_using_em, l_do_expldiff_rtm_thlm, &
        l_Lscale_plume_centered, l_diag_Lscale_from_tau, &
        l_use_C7_Richardson, l_use_C11_Richardson, &
        l_use_shear_Richardson, l_brunt_vaisala_freq_moist, &
        l_use_thvm_in_bv_freq, l_rcm_supersat_adj, &
        l_damp_wp3_Skw_squared, l_prescribed_avg_deltaz, &
        l_lmm_stepping, l_e3sm_config, l_vary_convect_depth, &
        l_use_tke_in_wp3_pr_turb_term, l_use_tke_in_wp2_wp3_K_dfsn, &
        l_use_wp3_lim_with_smth_Heaviside, &
        l_smooth_Heaviside_tau_wpxp, &
        l_modify_limiters_for_cnvg_test, &
